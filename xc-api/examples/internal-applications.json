{
  "tenant_name": "my-tenant",
  "namespace": "system",
  "virtual_site": {
    "name": "vsite-single-node-vsite",
    "namespace": "system"
  },
  "defaults": {
    "origin_server_type": "private_name",
    "origin_port": 8080,
    "endpoint_selection": "LOCALPREFERED",
    "loadbalancer_algorithm": "LB_OVERRIDE"
  },
  "applications": {
    "internal-api": {
      "domains": [
        "api.internal.example.com"
      ],
      "listener_port": 8080,
      "origin_server_value": "api.service.local",
      "advertise_network": "SITE_NETWORK_INSIDE"
    },
    "internal-admin": {
      "domains": [
        "admin.internal.example.com"
      ],
      "listener_port": 8443,
      "origin_server_type": "private_ip",
      "origin_server_value": "10.10.2.20",
      "origin_port": 8443,
      "advertise_network": "SITE_NETWORK_INSIDE"
    }
  }
}
